# AI Meta-Clinician Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================================
# SUPABASE CONFIGURATION
# Get these from your Supabase project settings:
# https://app.supabase.com/project/_/settings/api
# ============================================================

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Your Supabase anon/public key (safe to expose in client-side code)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================================
# OPTIONAL: FUTURE INTEGRATIONS
# ============================================================

# OpenAI API Key (if you want to add cloud LLM fallback)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (Claude)
# ANTHROPIC_API_KEY=...

# Sentry DSN (for error monitoring)
# NEXT_PUBLIC_SENTRY_DSN=...

# Google Analytics ID (for usage analytics)
# NEXT_PUBLIC_GA_ID=...

# ============================================================
# DEVELOPMENT NOTES
# ============================================================

# - Never commit .env.local to version control
# - Keep .env.example for team reference
# - Use Vercel Environment Variables for production deployment
# - Rotate keys if accidentally exposed
